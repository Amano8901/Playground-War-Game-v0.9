rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, role, experience, currentSessionId
    //
    // Collection: sessions
    // Fields: status, scores, hotspots, turnCount, lastUpdated, createdBy
    //
    // Collection: sessions/{sessionId}/actions
    // Fields: sessionId, userId, role, description, impact, timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "gcg8901@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string && data.uid.size() < 128 &&
             data.email is string && data.email.size() < 256 &&
             data.role in ['Diplomat', 'General', 'Intelligence Director', 'Economic Advisor'] &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100));
    }

    function isValidSession(data) {
      return data.keys().hasAll(['status', 'scores', 'createdBy']) &&
             data.status in ['active', 'completed'] &&
             data.scores is map &&
             data.createdBy is string && data.createdBy.size() < 128 &&
             (!('hotspots' in data) || (data.hotspots is list && data.hotspots.size() < 50));
    }

    function isValidAction(data) {
      return data.keys().hasAll(['sessionId', 'userId', 'description', 'timestamp']) &&
             data.sessionId is string && data.sessionId.size() < 128 &&
             data.userId is string && data.userId.size() < 128 &&
             data.description is string && data.description.size() < 2000 &&
             (!('role' in data) || (data.role is string && data.role.size() < 100));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    request.resource.data.uid == resource.data.uid;
    }

    match /sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidSession(request.resource.data) && 
                    request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.createdBy == request.auth.uid || isAdmin()) &&
                    isValidSession(request.resource.data);
      allow delete: if isAdmin();

      match /actions/{actionId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidAction(request.resource.data) &&
                      request.resource.data.userId == request.auth.uid;
      }
    }
  }
}
